# Soulseek credentials
SLSK_USER=
SLSK_PASS=

# Spotify app credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must be registered in your Spotify app settings exactly as below
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional: override download output directory (default: ~/Music/slsk-downloads)
# OUTPUT_DIR=/path/to/your/music
